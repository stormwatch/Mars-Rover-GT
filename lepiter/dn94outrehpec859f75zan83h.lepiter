										},
										"uid" : {
											"__type" : "uid",
											"uidString" : "FMvk3Sn6DQCHJV5xCgh/5g=="
										},
										"paragraphStyle" : {
											"__type" : "textStyle"
										},
										"string" : "- We have tested the context menu algorithm\n- We have tested documentation\nIn addition to this: I developed that interactive view to implement the layout algorithm. *I would not be able to handle easily bunch of numbers, representing points and rectangles in my head*, trying to figure out why a context menu is not properly placed. "
									}
								]
							},
							"createEmail" : {
								"__type" : "email",
								"emailString" : "<unknown>"
							},
							"createTime" : {
								"__type" : "time",
								"time" : {
									"__type" : "dateAndTime",
									"dateAndTimeString" : "2025-09-02T00:20:25.817935+01:00"
								}
							},
							"editEmail" : {
								"__type" : "email",
								"emailString" : "<unknown>"
							},
							"editTime" : {
								"__type" : "time",
								"time" : {
									"__type" : "dateAndTime",
									"dateAndTimeString" : "2025-09-02T00:36:23.932274+01:00"
								}
							},
							"uid" : {
								"__type" : "uid",
								"uidString" : "U3Z5Wif6DQCNEKlxCgh/5g=="
							},
							"paragraphStyle" : {
								"__type" : "textStyle"
							},
							"string" : " [I asked about my confusion](https://discord.com/channels/729445214812504107/736333725788274819/1412113668610588742) in Discord. Juraj Kubelka pointed to one of the documented use cases {{gtPage:Explaining the context menu and dropdown algorithm|db=2j9m7db2i4oz116bexd7wbdxo}} and added that by virtue of examples:"
						},
						{
							"__type" : "textSnippet",
							"children" : {
								"__type" : "snippets",
								"items" : [
									{
										"__type" : "youtubeSnippet",
										"children" : {
											"__type" : "snippets",
											"items" : [ ]
										},
										"createEmail" : {
											"__type" : "email",
											"emailString" : "<unknown>"
										},
										"createTime" : {
