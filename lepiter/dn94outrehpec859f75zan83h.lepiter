							},
							"uid" : {
								"__type" : "uid",
								"uidString" : "ZZmLVyj6DQCAePWCCgh/5g=="
							},
							"paragraphStyle" : {
								"__type" : "textStyle"
							},
							"string" : "Tudor Gîrba shared [Example-driven development: bridging tests and documentation](https://arxiv.org/abs/2409.00514) presented by Oscar Nierstrasz at the [Live 2024](https://2024.splashcon.org/home/live-2024#event-overview) Workshop."
						},
						{
							"__type" : "textSnippet",
							"children" : {
								"__type" : "snippets",
								"items" : [
									{
										"__type" : "textSnippet",
										"children" : {
											"__type" : "snippets",
											"items" : [ ]
										},
										"createEmail" : {
											"__type" : "email",
											"emailString" : "<unknown>"
										},
										"createTime" : {
											"__type" : "time",
											"time" : {
												"__type" : "dateAndTime",
												"dateAndTimeString" : "2025-09-02T03:15:45.367766+01:00"
											}
										},
										"editEmail" : {
											"__type" : "email",
											"emailString" : "<unknown>"
										},
										"editTime" : {
											"__type" : "time",
											"time" : {
												"__type" : "dateAndTime",
												"dateAndTimeString" : "2025-09-02T03:18:01.221731+01:00"
											}
										},
										"uid" : {
											"__type" : "uid",
											"uidString" : "Iw99zSn6DQCFXt4YCgh/5g=="
										},
										"paragraphStyle" : {
											"__type" : "textStyle"
										},
										"string" : "(…) when the returned objects are combined with views, we get documentation essentially for free. This ability can be directly used in conversations with domain experts: the examples produce objects that can be viewed in ways that non-technical people can relate to."
									}
								]
							},
